# ==============================================================================
# Prompt Folio Environment Configuration
# ==============================================================================
# Copy this file to .env and replace the placeholder values with your own.
# ==============================================================================

# ------------------------------------------------------------------------------
# Core Application Settings
# ------------------------------------------------------------------------------

# Environment mode: Use "DEV" for local development, "PROD" for production.
# Determines logging levels and certain security fallbacks.
ENVIRONMENT=DEV

# The base domain the application is served on.
# Used for scoping security cookies. For local dev, use "localhost" or a local domain.
APP_DOMAIN=localhost

# Password used to access the /manage admin dashboard.
ADMIN_PASSWORD=change_this_to_a_secure_password

# SQLite database connection string.
SQLITE_URL=sqlite+aiosqlite:///private/sessions.db

# ------------------------------------------------------------------------------
# External API Integrations
# ------------------------------------------------------------------------------

# Mistral AI API Key for driving the chat assistant.
# Get one at: https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# ------------------------------------------------------------------------------
# Default UI Configuration (Optional)
# ------------------------------------------------------------------------------
# These settings define the default appearance for a new deployment.
# They are only used if the user hasn't explicitly saved custom settings via the /manage dashboard.

# Default profile name for the AI to represent.
DEFAULT_OWNER_NAME=Tibor

# Default Theme Colors (Hex format)
DEFAULT_COLOR_SHADOW_GREY=#1e1e24
DEFAULT_COLOR_SWEET_SALMON=#fb9f89
DEFAULT_COLOR_KHAKI_BEIGE=#c4af9a
DEFAULT_COLOR_MUTED_TEAL=#81ae9d
DEFAULT_COLOR_SEAWEED=#21a179

# ------------------------------------------------------------------------------
# Optional Services
# ------------------------------------------------------------------------------

# Google reCAPTCHA v3 keys (Optional: leave blank to disable)
RECAPTCHA_CLIENT_SIDE_KEY=
RECAPTCHA_SERVER_SIDE_KEY=

# Ntfy.sh topic for push notifications (Optional: leave blank to disable)
# E.g. prompt_folio_alerts_1234
NTFY_TOPIC=

# ------------------------------------------------------------------------------
# Deployment Settings (Used by deploy.sh)
# ------------------------------------------------------------------------------

# The remote SSH host where the application will be deployed
REMOTE_HOST=your_production_ssh_host

# The absolute path on the remote host where the application will reside
REMOTE_PATH=/opt/prompt-folio

# The Docker Registry to push the image to (leave empty for Docker Hub)
DOCKER_REGISTRY=registry.casteleijn.com

# The name of the Docker repository/image
DOCKER_IMAGE_NAME=prompt-folio

# Port to expose the application on locally (and via docker-compose)
PORT=3005
